# ─────────────────────────────────────────────────────────────────────────────
# Stock Portfolio Manager — environment variables
# Copy this file to .env and fill in values for local development.
# Production values are read from GCP Secret Manager automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Local tooling ─────────────────────────────────────────────────────────────
# Path to node binaries (output of: dirname $(which node))
NODE_BIN=/Users/YOU/.nvm/versions/node/v22.0.0/bin

# Path to the legacy harvester SQLite database
HARVESTER_DB_PATH=/path/to/StockPortfolioManager/harvester.sqlite

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: point at the Cloud SQL Proxy (started by `make proxy`)
# Format: postgresql+psycopg2://USER:PASS@127.0.0.1:5433/DBNAME
DATABASE_URL=postgresql+psycopg2://app_user:PASSWORD@127.0.0.1:5433/stock_portfolio

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate locally with: python -c "import secrets; print(secrets.token_hex(32))"
# In production this is stored in Secret Manager as `jwt-secret`
JWT_SECRET=your-local-dev-secret-here

# Google OAuth 2.0 credentials (from console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET
# Must match the redirect URI registered in the OAuth consent screen
GOOGLE_REDIRECT_URI=http://localhost:5001/auth/callback

# ── GCP ───────────────────────────────────────────────────────────────────────
# Required for Secret Manager fallback and Pub/Sub
GCP_PROJECT=stock-portfolio-tfowler

# ── Agents ────────────────────────────────────────────────────────────────────
# Set to false to disable Pub/Sub publishing in local dev (avoids ADC requirement)
PUBSUB_ENABLED=false

# Circuit breakers — set to false to run agents outside market hours
CIRCUIT_BREAKER_ENABLED=true

# Deep Analysis concurrency cap per process
DEEP_ANALYSIS_MAX_CONCURRENT=3

# ── Cloud Run (set automatically — do not set locally) ────────────────────────
# K_SERVICE=stock-portfolio-api   # set by Cloud Run; enables JSON logging
# PORT=8080                       # set by Cloud Run; gunicorn binds to this
